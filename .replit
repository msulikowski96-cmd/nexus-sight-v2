modules = ["nodejs-20", "postgresql-16"]

[[ports]]
localPort = 3001
externalPort = 6800

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 6000

[[ports]]
localPort = 10000
externalPort = 8000

[[ports]]
localPort = 20250
externalPort = 3002

[[ports]]
localPort = 20251
externalPort = 3003

[[ports]]
localPort = 20252
externalPort = 5000

[[ports]]
localPort = 22333
externalPort = 3000

[[ports]]
localPort = 22334
externalPort = 3001

[[ports]]
localPort = 22335
externalPort = 5173

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "artifacts/web: web"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/web"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/web run dev"
cwd = "./artifacts/web"
waitForPort = 22333
router = "path"

[workflows.workflow.tasks.env]
PORT = "22333"
BASE_PATH = "/"

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "XegfDyZt7HqfW2Bb8Ghoy"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mockup-sandbox run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 8081

[workflows.workflow.tasks.env]
PORT = "8081"
BASE_PATH = "/__mockup"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "3B4_FFSkEVBkAeYMFRJ2e"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
cwd = "./artifacts/api-server"
waitForPort = 8080

[workflows.workflow.tasks.env]
PORT = "8080"

[[workflows.workflow]]
name = "run"
mode = "parallel"
author = 56893852

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/web: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/mockup-sandbox: Component Preview Server"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/lol-overlay: LoL Overlay UI Preview"

[[workflows.workflow]]
name = "artifacts/lol-overlay: LoL Overlay UI Preview"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/lol-overlay run dev:vite"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "webview"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "pnpm install && pnpm --filter @workspace/web run build && pnpm --filter @workspace/api-server run build"]
run = ["sh", "-c", "NODE_ENV=production pnpm --filter @workspace/db run push && NODE_ENV=production PORT=10000 node artifacts/api-server/dist/index.mjs"]

[nix]
channel = "stable-25_05"
